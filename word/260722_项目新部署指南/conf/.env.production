# ============================================================

# Django
DJANGO_SECRET_KEY=qisi_jwt_secret_key_2026_development
DJANGO_DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,42.194.195.78,qisi.chengxuelu.com

# Database - PostgreSQL 18.4（app-pgsql 容器，端口已发布到宿主机）
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=pgsql!1804pwd
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery - Redis 7.2（qisi-redis 容器，端口已发布到宿主机）
# 使用 DB 1/2/3 避免不同服务间 key 冲突（DB 0 保留）
CELERY_BROKER_URL=redis://:redis172pwd@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis172pwd@localhost:6379/2
CACHE_URL=redis://:redis172pwd@localhost:6379/3
CELERY_TASK_ALWAYS_EAGER=False
REDIS_PASSWORD=redis172pwd
REDIS_HOST=localhost
REDIS_PORT=6379

