    {
      "schema_version": "1.0",
      "record_type": "question",
      "question_id": "SZMS_2022_2023_G8_PHYSICS_MIDTERM_Q06",
      "paper_id": "SZMS_2022_2023_G8_PHYSICS_MIDTERM",
      "question_no": "6",
      "section": "二、双选题（本题共5小题，共10分）",
      "question_type": "multiple_choice",
      "material": null,
      "stem": "下列语句中加引号部分描绘的运动情景，选取船为参照物的是（　　）",
      "options": [
        {
          "label": "A",
          "content": "两岸“青山”相对出，孤帆一片日边来"
        },
        {
          "label": "B",
          "content": "仔细看山“山”不动，是船行"
        },
        {
          "label": "C",
          "content": "满眼风光多闪灼，看“山”恰似走来迎"
        },
        {
          "label": "D",
          "content": "两岸猿声啼不住，“轻舟”已过万重山"
        }
      ],
      "subquestions": [],
      "answer": {
        "raw": "AC",
        "normalized": [
          "A",
          "C"
        ]
      },
      "analysis": "A．“青山”相对出，即青山是运动的，而山的运动是以孤帆为参照物的，故A符合题意；\nB．仔细看山“山”不动，即山是静止的，而以船为参照物，山有位置变化，是运动的，故B不符合题意；\nC．看“山”恰似走来迎，即山是运动的，而“满眼风光多闪灼”说明是在船上看到风光变化，即山相对船有位置变化，所以所选的参照物是船，故C符合题意；\nD．“轻舟”已过万重山，轻舟相对山而言有位置变化，所以是以山为参照物的，故D不符合题意。\n故选AC。",
      "illustrations": [],
      "tables": [],
      "formula_assets": [],
      "source": {
        "page_start": 5,
        "page_end": 6
      },
      "quality": {
        "warnings": [],
        "requires_review": false
      }
    },
    {
      "schema_version": "1.0",
      "record_type": "question",
      "question_id": "SZMS_2022_2023_G8_PHYSICS_MIDTERM_Q07",
      "paper_id": "SZMS_2022_2023_G8_PHYSICS_MIDTERM",
      "question_no": "7",
      "section": "二、双选题（本题共5小题，共10分）",
      "question_type": "multiple_choice",
      "material": null,
      "stem": "下列说法中，正确的是（　　）",
      "options": [
        {
          "label": "A",
          "content": "一切正在发声的物体都在振动"
        },
        {
          "label": "B",
          "content": "一般情况下，声音在气体、液体、固体中的传播速度关系是v气<v液<v固"
        },
        {
          "label": "C",
          "content": "摩托车安装消声器是为了防止噪声产生"
        },
        {
          "label": "D",
          "content": "只要我们观察到物体在振动，我们就能听到它发出的声音"
        }
      ],
      "subquestions": [],
      "answer": {
        "raw": "AC",
        "normalized": [
          "A",
          "C"
        ]
      },
      "analysis": "A．声音是由物体的振动产生的，一切正在发声的物体都在振动，故A正确；\nB．一般情况下，声音在气体、液体、固体中的传播速度关系是v气<v液<v固，故B错误；\nC．摩托车安装消声器是从声源处控制噪声，是为了防止噪声产生，故C正确；\nD．我们之所以能听到声音，是声源的振动通过媒介传到我们的耳朵，如果只有声源，没有传声介质或听觉器官，是听不到声音的，故D错误。\n故选AC。",
      "illustrations": [],
      "tables": [],
