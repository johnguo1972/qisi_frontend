"""AI prompt templates for knowledge analysis and A/B/C mode answer generation."""


class AIPrompts:
    """Prompt templates for the 4-step AI processing pipeline."""

    @classmethod
    def knowledge_analysis(cls, question_text: str, question_answer: str = '',
                           question_analysis: str = '', question_solution: str = '',
                           image_descriptions: list = None) -> dict:
        """Prompt for knowledge point identification.

        Returns: {"system": str, "user": str}
        """
        image_hint = ""
        if image_descriptions:
            image_hint = "\n【题目关联图片信息】\n" + "\n".join(f"- {desc}" for desc in image_descriptions)

        system = """你是一个数理化知识点分析专家。你的任务是分析一道题目涉及的核心知识点、适用年级、题目难度和解题方法。

严格规则：
1. 从候选知识点中选择 1-5 个最相关的知识点（不要超过 5 个）。
2. 年级学期判定：如果题目涵盖 3 个以上知识点或是综合题，统一归为"高三下学期"或"初三下学期"。
3. 难度评估：L1=基础题（单一知识点直接应用）, L2=中等题（2-3个知识点综合）, L3=较难题（需要技巧和变形）, L4=中高考押轴题难度, L5=竞赛题难度。
4. 解题方法给出 1-3 个主要方法。
5. 输出必须是标准 JSON，不要输出 Markdown、代码块或额外说明。
6. 所有数学公式使用 $ $ (行内) 或 $$ $$ (块级) 包裹。

输出字段固定为：
knowledge_points (数组，每项包含 id/module/subject/full_label),
grade_term (对象，包含 stage/grade_index/grade_name/term/label),
difficulty (字符串: "L1" | "L2" | "L3" | "L4" | "L5"),
solving_methods (字符串数组)"""

        user = f"""请分析以下题目的知识点归属。

【题干】
{question_text}
{image_hint}

【参考答案】
{question_answer or '无'}

【解析】
{question_analysis or '无'}

【详细解答】
{question_solution or '无'}

【候选知识点列表（请从中选择 1-5 个最相关的）】：
{{knowledge_points_list}}

请输出 JSON。"""

        return {"system": system, "user": user}

    @classmethod
    def mode_a_answer(cls, question_text: str, knowledge_refs: str = '',
                      question_answer: str = '', question_analysis: str = '',
                      question_solution: str = '',
                      image_descriptions: list = None) -> dict:
        """A mode: 3-5 step direct answer.

        Returns: {"system": str, "user": str}
        """
        image_hint = ""
        if image_descriptions:
            image_hint = "\n【题目关联图片信息】\n" + "\n".join(f"- {desc}" for desc in image_descriptions)

        system = """你是一位数理化解题专家。

当前为 A 模式。
任务目标：
1. 给出 3 到 5 步简化步骤。
2. 每一步的中文说明建议控制在 50 个字左右。
3. 每一步都要围绕关键推理，不要展开冗长背景解释。
4. 必须给出最终答案。
5. 必须给出简洁的解题总结（100字左右）。
6. 所有包含数学公式、变量字母和符号的内容必须使用 $ $ (行内) 或 $$ $$ (块级) 包裹。
7. 输出必须是标准 JSON，不要输出 Markdown、代码块或额外说明。

严格规则：
1. 只能依据题干中的客观事实求解。
2. 如果信息不足，必须在 missing_conditions 中明确指出。
3. 禁止自行补充任何未给出的条件。

输出字段固定为：
mode, subject, difficulty, core_ideas, steps, final_answer, summary, missing_conditions"""

        user = f"""请按 A 模式解题，并输出 JSON。

【题干】
{question_text}
{image_hint}

【已有参考答案】
{question_answer or '无'}

【已有解析】
{question_analysis or '无'}

【已有详细解答】
{question_solution or '无'}

【知识点参考】
{knowledge_refs or '无'}

要求：
1. steps 数量只能是 3、4 或 5。
2. 每个步骤都应包含必要公式或关键关系，以 $ $ 形式包裹。

请输出 JSON。"""

        return {"system": system, "user": user}

    @classmethod
    def mode_b_answer(cls, question_text: str, knowledge_refs: str = '',
                      question_answer: str = '', question_analysis: str = '',
                      question_solution: str = '',
                      image_descriptions: list = None) -> dict:
        """B mode: Socratic guided multiple-choice questions.

        Returns: {"system": str, "user": str}
        """
        image_hint = ""
        if image_descriptions:
            image_hint = "\n【题目关联图片信息】\n" + "\n".join(f"- {desc}" for desc in image_descriptions)

        system = """你是一位高中数学与物理竞赛教练。

当前为 B 模式。
任务目标：
1. 设计 3 到 4 个连续递进的小问题。
2. 每个问题必须有 4 个固定选项，选项键只能是 A、B、C、D。
3. 每个问题都必须给出 correct_option、reference_answer、analysis。
4. 问题顺序必须从"读题观察"到"核心推理"再到"最终结论"。
5. 必须给出解题总结和最终答案。
6. 所有包含数学公式、变量字母和符号的内容必须使用 $ $ (行内) 或 $$ $$ (块级) 包裹。
7. 输出必须是标准 JSON，不要输出 Markdown、代码块或额外说明。

严格规则：
1. 问题必须紧贴本题，不可泛化成空泛教学题。
2. 选项必须互斥且尽量避免明显送分项。
3. questions 数量只能是 3 或 4。

输出字段固定为：
mode, subject, difficulty, core_ideas, questions, final_answer, summary, missing_conditions"""

        user = f"""请按 B 模式输出 JSON。

【题干】
{question_text}
{image_hint}

【已有参考答案】
{question_answer or '无'}

【已有解析】
{question_analysis or '无'}

【已有详细解答】
{question_solution or '无'}

【知识点参考】
{knowledge_refs or '无'}

要求：
1. questions 数量只能是 3 或 4。
2. 每个问题必须包含：id, question, options, correct_option, reference_answer, analysis。
3. options 中必须严格包含 A、B、C、D 四个键。

请输出 JSON。"""

        return {"system": system, "user": user}

    @classmethod
    def mode_c_answer(cls, question_text: str, knowledge_refs: str = '',
                      question_answer: str = '', question_analysis: str = '',
                      question_solution: str = '',
                      image_descriptions: list = None) -> dict:
        """C mode: Socratic open-ended guided questions.

        Returns: {"system": str, "user": str}
        """
        image_hint = ""
        if image_descriptions:
            image_hint = "\n【题目关联图片信息】\n" + "\n".join(f"- {desc}" for desc in image_descriptions)

        system = """你是一位高中数理化竞赛教练。

当前为 C 模式。
任务目标：按"识别结构->建立关系->计算结论"设计 3 个开放性引导问题并输出 JSON。

规则：
1. 固定输出 3 个问题。
2. 每个问题必须包含：id, question, reference_answer, key_points, followup_hint。
3. key_points 固定给出 2 条核心评分点。
4. 所有包含数学公式、变量字母和符号的内容必须使用 $ $ (行内) 或 $$ $$ (块级) 包裹。
5. final_answer 给出完整答案。
6. summary 仅限 1 句话。
7. 输出严格 JSON，无 Markdown，无解释。

输出字段：mode, subject, difficulty, core_ideas, questions, final_answer, summary, missing_conditions"""

        user = f"""请按 C 模式输出 JSON。

【题干】
{question_text}
{image_hint}

【已有参考答案】
{question_answer or '无'}

【已有解析】
{question_analysis or '无'}

【已有详细解答】
{question_solution or '无'}

【知识点参考】
{knowledge_refs or '无'}

要求：
1. questions 数组长度必须为 3。
2. key_points 数组长度必须为 2。
3. missing_conditions 若无则固定为 []。

请输出 JSON。"""

        return {"system": system, "user": user}
